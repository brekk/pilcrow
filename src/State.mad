import type { Maybe } from "Maybe"

import { Just, Nothing } from "Maybe"



export alias PilcrowState = {
  auto :: Boolean,
  input :: Maybe String,
  madlibJson :: Maybe String,
  output :: Maybe String,
  overwrite :: Boolean,
  showHelp :: Boolean,
}


INITIAL_STATE :: PilcrowState
export INITIAL_STATE = {
  auto: false,
  input: Nothing,
  madlibJson: Nothing,
  output: Nothing,
  overwrite: false,
  showHelp: false,
}
